# ============================================================
# AgentMart Environment Variables
# Copy this file to .env and fill in real values
# ============================================================

# ------- App -------
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true
SECRET_KEY=your-secret-key-change-this-in-production

# ------- Database -------
DATABASE_URL=postgresql://agentmart:password@localhost:5432/agentmart
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# ------- Redis -------
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=3600

# ------- JD (京东开放平台) -------
# https://open.jd.com/
JD_APP_KEY=your_jd_app_key
JD_APP_SECRET=your_jd_app_secret
JD_ACCESS_TOKEN=your_jd_access_token
JD_API_BASE_URL=https://api.jd.com/routerjson

# ------- Taobao/Tmall (淘宝开放平台) -------
# https://open.taobao.com/
TAOBAO_APP_KEY=your_taobao_app_key
TAOBAO_APP_SECRET=your_taobao_app_secret
TAOBAO_ACCESS_TOKEN=your_taobao_access_token
TAOBAO_API_BASE_URL=https://eco.taobao.com/router/rest

# ------- Bilibili -------
# bilibili-api-python uses SESSDATA cookie
BILIBILI_SESSDATA=your_bilibili_sessdata
BILIBILI_BILI_JCT=your_bili_jct
BILIBILI_BUVID3=your_buvid3
BILIBILI_DEDEUSERID=your_dedeuserid

# ------- Douyin -------
# https://open.douyin.com/
DOUYIN_CLIENT_KEY=your_douyin_client_key
DOUYIN_CLIENT_SECRET=your_douyin_client_secret
DOUYIN_ACCESS_TOKEN=your_douyin_access_token

# ------- LLM APIs (reserved, not used in v1) -------
OPENAI_API_KEY=sk-your-openai-key
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

DEEPSEEK_API_KEY=your-deepseek-key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

CLAUDE_API_KEY=your-claude-key
CLAUDE_MODEL=claude-3-5-sonnet-20241022

# ------- Whisper (ASR for video transcription) -------
WHISPER_MODEL=base
WHISPER_DEVICE=cpu

# ------- Celery -------
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ------- CORS -------
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173","http://127.0.0.1:5500"]
